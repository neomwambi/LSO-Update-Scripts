# Copy to .env and fill in (never commit .env). VPN on when connecting.
# Colleagues can skip .env and use “Connect with my credentials” in the web UI instead.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=policies_prod

# API bind address (default 127.0.0.1). Only change if you know you need it.
# LISTEN_HOST=127.0.0.1

# Optional: restrict API upload temp dir (default system temp)
# UPLOAD_DIR=
